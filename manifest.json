{
  "manifest_version": 3,
  "name": "Save Articles to Notion",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:5678/*"],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://medium.com/*",
        "https://*.substack.com/*"
        ],
      "js": ["content.js"]
    }
  ]
}